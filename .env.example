# Omnidesk API Configuration
# Получите API-ключ в настройках Omnidesk: Настройки -> API -> Создать ключ
OMNIDESK_API_KEY=your_api_key_here

# Для веб-скрапинга (если нет API-ключа)
OMNIDESK_EMAIL=your_email@iridi.com
OMNIDESK_PASSWORD=your_password

# Базовый URL аккаунта Omnidesk (обычно https://account.omnidesk.com)
OMNIDESK_API_BASE=https://iridi.omnidesk.ru

# Настройки веб-интерфейса
HOST=0.0.0.0
PORT=7987
