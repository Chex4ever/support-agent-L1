# Omnidesk API Configuration
# Получите API-ключ в настройках Omnidesk: Настройки -> API -> Создать ключ
OMNIDESK_API_KEY=your_api_key_here

# Email сотрудника для API-аутентификации (HTTP Basic Auth с email:api_key)
OMNIDESK_STAFF_EMAIL=your_email@iridi.com

# Для веб-скрапинга (если нет API-ключа)
OMNIDESK_EMAIL=your_email@iridi.com
OMNIDESK_PASSWORD=your_password

# Базовый URL аккаунта Omnidesk
OMNIDESK_API_BASE=https://iridi.omnidesk.ru

# Redmine API Configuration
# Получите API-ключ в Redmine: Profile -> API access key -> Show
REDMINE_API_KEY=your_redmine_api_key_here
REDMINE_API_BASE=https://redmine.iridi.nt

# BookStack API Configuration
# Получите в настройках BookStack: Настройки -> API-токены -> Создать токен
BOOKSTACK_TOKEN_ID=your_token_id_here
BOOKSTACK_TOKEN_SECRET=your_token_secret_here
BOOKSTACK_BASE_URL=http://bookstack.mytunnel.org
BOOKSTACK_NAME=your_display_name

# Настройки веб-интерфейса
HOST=0.0.0.0
PORT=7989
